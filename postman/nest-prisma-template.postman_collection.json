{
  "info": {
    "_postman_id": "nest-prisma-template-collection",
    "name": "NestJS Prisma Template API",
    "description": "Complete API collection for the NestJS Prisma Template.\n\n**Base URL:** `{{baseUrl}}/api/v1`\n\n**How to use:**\n1. Import this collection.\n2. Set `baseUrl` in the environment (default: `http://localhost:3000`).\n3. Hit **Login** — `accessToken`, `userToken` or `adminToken` are set automatically based on the returned role.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",     "value": "http://localhost:3000", "type": "string" },
    { "key": "accessToken", "value": "",                      "type": "string" },
    { "key": "userToken",   "value": "",                      "type": "string" },
    { "key": "adminToken",  "value": "",                      "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Authentication & authorization endpoints",
      "item": [
        {
          "name": "Sign Up",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "signup"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"phone\": \"01700000000\",\n  \"password\": \"Password@123\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"statusCode\": 201,\n  \"message\": \"Registration successful. Please verify your email\",\n  \"meta\": null,\n  \"data\": {\n    \"userId\": \"uuid\",\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"phone\": \"01700000000\",\n    \"profile\": null,\n    \"role\": \"USER\"\n  },\n  \"timestamp\": \"2026-05-18T16:00:00.000Z\"\n}"
            }
          ]
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res && res.data && res.data.tokens) {",
                  "  const token = res.data.tokens.accessToken;",
                  "  const role  = res.data.user && res.data.user.role;",
                  "",
                  "  // Always store the generic accessToken",
                  "  pm.collectionVariables.set('accessToken', token);",
                  "",
                  "  // Store role-specific token",
                  "  if (role === 'USER' || role === 'ELEVATOR') {",
                  "    pm.collectionVariables.set('userToken', token);",
                  "    console.log('userToken set for role:', role);",
                  "  } else if (role === 'ADMIN' || role === 'SUPER_ADMIN') {",
                  "    pm.collectionVariables.set('adminToken', token);",
                  "    console.log('adminToken set for role:', role);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"Password@123\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"statusCode\": 200,\n  \"message\": \"Login successful\",\n  \"meta\": null,\n  \"data\": {\n    \"tokens\": {\n      \"accessToken\": \"eyJhbGciOiJIUzI1NiJ9...\",\n      \"refreshToken\": \"eyJhbGciOiJIUzI1NiJ9...\"\n    },\n    \"user\": {\n      \"userId\": \"uuid\",\n      \"name\": \"John Doe\",\n      \"email\": \"john@example.com\",\n      \"phone\": \"01700000000\",\n      \"role\": \"USER\"\n    }\n  },\n  \"timestamp\": \"2026-05-18T16:00:00.000Z\"\n}"
            }
          ]
        },
        {
          "name": "Login as Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res && res.data && res.data.tokens) {",
                  "  const token = res.data.tokens.accessToken;",
                  "  const role  = res.data.user && res.data.user.role;",
                  "",
                  "  pm.collectionVariables.set('accessToken', token);",
                  "",
                  "  if (role === 'USER' || role === 'ELEVATOR') {",
                  "    pm.collectionVariables.set('userToken', token);",
                  "    console.log('userToken set for role:', role);",
                  "  } else if (role === 'ADMIN' || role === 'SUPER_ADMIN') {",
                  "    pm.collectionVariables.set('adminToken', token);",
                  "    console.log('adminToken set for role:', role);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@servicemarketplace.com\",\n  \"password\": \"SuperSecurePassword123!\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/refresh-token",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "refresh-token"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"<userId>\",\n  \"refreshToken\": \"<refreshToken>\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"statusCode\": 200,\n  \"message\": \"Token refreshed successfully\",\n  \"meta\": null,\n  \"data\": {\n    \"accessToken\": \"eyJhbGciOiJIUzI1NiJ9...\",\n    \"refreshToken\": \"eyJhbGciOiJIUzI1NiJ9...\"\n  },\n  \"timestamp\": \"2026-05-18T16:00:00.000Z\"\n}"
            }
          ]
        },
        {
          "name": "Get Me (Current User)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "me"]
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"statusCode\": 200,\n  \"message\": \"User profile fetched successfully\",\n  \"meta\": null,\n  \"data\": {\n    \"userId\": \"uuid\",\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"phone\": \"01700000000\",\n    \"role\": \"USER\",\n    \"profile\": null,\n    \"isNotification\": true,\n    \"isAgree\": false,\n    \"verifidStatus\": \"REQUEST\",\n    \"createdAt\": \"2026-05-18T16:00:00.000Z\",\n    \"updatedAt\": \"2026-05-18T16:00:00.000Z\"\n  },\n  \"timestamp\": \"2026-05-18T16:00:00.000Z\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "User",
      "description": "User management endpoints",
      "item": []
    }
  ]
}
