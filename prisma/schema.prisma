// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
  MODERATOR
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  BANNED
}

enum BookCondition {
  NEW
  LIKE_NEW
  USED_GOOD
  USED_FAIR
  DAMAGED
}

enum BookStatus {
  AVAILABLE
  RESERVED
  SOLD
}

model User {
  userId          String    @id @default(uuid()) @db.Uuid
  profilePhotoUrl String?
  userName        String
  email           String    @unique
  contactNumber   String?   @unique
  password        String
  refreshToken    String?
  otpCode         String?
  otpExpiry       DateTime?

  role                  UserRole   @default(USER)
  status                UserStatus @default(ACTIVE)
  isVerified            Boolean    @default(false)
  verificationOtp       String?    @unique
  verificationOtpExpiry DateTime?
  lastLogin             DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  books             Book[]
  deletedCategories BookCategory[]  @relation("DeletedCategories")
  favourites        UserFavourite[]
  purchases         UserPurchase[]

  sentChats     Chat[] @relation("SentChats")
  receivedChats Chat[] @relation("ReceivedChats")

  createdRooms   ChatRoom[]
  roomMembers    ChatRoomMember[]
  bookCategories BookCategory[]
  notifications Notification[]
}

model Book {
  bookId String @id @default(uuid()) @db.Uuid

  bookCategoryId String  @db.Uuid
  bookName       String
  thumbnailUrl   String?
  authorName     String

  condition BookCondition
  status    BookStatus    @default(AVAILABLE)

  copyOwner String @db.Uuid

  isFree Boolean @default(false)
  price  Decimal @default(0) @db.Decimal(10, 2)

  description String?
  location    String?

  latitude  Decimal? @db.Decimal(10, 8)
  longitude Decimal? @db.Decimal(11, 8)

  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  owner User @relation(fields: [copyOwner], references: [userId])

  category BookCategory @relation(fields: [bookCategoryId], references: [bookCategoryId])

  images     BookImage[]
  favourites UserFavourite[]
  purchases  UserPurchase[]
}

model BookCategory {
  bookCategoryId String @id @default(uuid()) @db.Uuid

  categoryName String  @unique
  description  String?

  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  deletedBy     String?   @db.Uuid
  deletedByUser User?     @relation("DeletedCategories", fields: [deletedBy], references: [userId])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  books      Book[]
  user       User?   @relation(fields: [userUserId], references: [userId])
  userUserId String? @db.Uuid
}

model BookImage {
  previewId String @id @default(uuid()) @db.Uuid

  bookId   String @db.Uuid
  imageUrl String

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  book Book @relation(fields: [bookId], references: [bookId], onDelete: Cascade)
}

model UserFavourite {
  favId String @id @default(uuid()) @db.Uuid

  userId String @db.Uuid
  bookId String @db.Uuid

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [bookId], onDelete: Cascade)

  @@unique([userId, bookId])
}

model UserPurchase {
  purchaseId String @id @default(uuid()) @db.Uuid

  userId String @db.Uuid
  bookId String @db.Uuid

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [bookId], onDelete: Cascade)

  @@unique([userId, bookId])
}

model Chat {
  chatId String @id @default(uuid()) @db.Uuid

  senderId   String @db.Uuid
  receiverId String @db.Uuid

  roomId String? @db.Uuid

  message String

  isSeen Boolean @default(false)

  sentAt DateTime  @default(now())
  readAt DateTime?

  sender User @relation("SentChats", fields: [senderId], references: [userId], onDelete: Cascade)

  receiver User @relation("ReceivedChats", fields: [receiverId], references: [userId], onDelete: Cascade)

  room ChatRoom? @relation(fields: [roomId], references: [roomId], onDelete: Cascade)
}

model ChatRoom {
  roomId String @id @default(uuid()) @db.Uuid

  createdBy String @db.Uuid

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  creator User @relation(fields: [createdBy], references: [userId], onDelete: Cascade)

  chats   Chat[]
  members ChatRoomMember[]
}

model ChatRoomMember {
  id String @id @default(uuid()) @db.Uuid

  roomId String @db.Uuid
  userId String @db.Uuid

  joinedAt DateTime @default(now())

  room ChatRoom @relation(fields: [roomId], references: [roomId], onDelete: Cascade)

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([roomId, userId])
}


enum NotificationType {
  MESSAGE
  BOOK_LIKED
  BOOK_PURCHASED
}

model Notification {
  notificationId String @id @default(uuid()) @db.Uuid

  receiverId String @db.Uuid

  title String
  body String

  type NotificationType

  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  receiver User @relation(fields:[receiverId], references:[userId], onDelete: Cascade)
}